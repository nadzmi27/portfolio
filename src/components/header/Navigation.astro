---
import { FolderOpen } from "@lucide/astro";
const base = import.meta.env.BASE_URL;
const segments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbs = segments.map((segment, index) => ({
  label: segment,
  href: "/" + segments.slice(0, index + 1).join("/"),
})).slice(1);
const current = breadcrumbs[breadcrumbs.length - 1];
const ancestors = breadcrumbs.slice(0, -1);
console.log(segments)
---

<div class="flex items-center">
  <a href={base} class="flex items-center">
    <span class="nav-link">~</span>
    <span class="ml-2">/</span>

    <span class="flex items-center nav-link">
      <FolderOpen class="ml-2 mr-1" size={18} />
      portfolio
    </span>
  </a>
  <span class="ml-1"></span>

  {
    ancestors.map((crumb) => {
      const href = crumb.href;
      return (
        <>
          {"/"}
          <a href={href} class="hover:text-amber-300 mx-1">
            {crumb.label}
          </a>
        </>
      );
    })
  }

  {/* current (NOT clickable) */}
  {
    current && (
      <>
        <span class="mr-1">/</span>
        <span>{current.label}</span>
      </>
    )
  }

  <span class="ml-1">/</span>
  <span
    class="relative bottom-[-1.5px] h-[16px] w-[6px] ml-1 bg-nav-link animate-[terminal-fade_3s_ease-in-out_infinite]"
  ></span>
</div>
