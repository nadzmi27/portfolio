---
import { Icon } from "astro-icon/components";
import Link from "../Layout/Link.astro";
import Tooltip from "../Tooltip";
import { Image } from "astro:assets";

interface Tags {
  icon?: string;
  name?: string;
  size?: number;
  color?: string;
}

interface Props {
  title: string;
  date: Date;
  description: string;
  image?: ImageMetadata;
  imageAlt?: string;
  href?: string;
  tooltip?: string;
  tags?: Tags[];
  readingTime: number;
}

const {
  title,
  date,
  description,
  image,
  imageAlt = "",
  href = "#",
  tooltip = "",
  tags,
  readingTime = 15,
} = Astro.props;
---

<div class="relative">
  <Tooltip client:visible tooltip={tooltip}>
    <Link
      href={href}
      openNew={false}
      class="flex flex-col sm:flex-row border p-4 gap-4"
      >{
        image && (
          <Image
            src={image}
            alt={imageAlt}
            loading="eager"
            class="w-full sm:w-[256px] h-auto block border self-start"
          />
        )
      }

      <div class="flex flex-col">
        <h1 class="font-semibold text-xl mb-2">{title}</h1>
        <p class="mb-1 text-pretty">{description}</p>
        <span class="flex flex-row gap-2 items-center mb-1"
          >{
            date.toLocaleDateString("en-AU", {
              year: "numeric",
              month: "long",
              day: "2-digit",
            })
          }
          <span class="border-l h-4 border-black/70"></span>
          {readingTime} min read
        </span>
        <!-- Tags -->
        <div class="flex flex-wrap gap-2">
          {
            tags?.map((tag) => (
              <div
                class="card-texture flex items-center gap-1.5 px-2 py-1 lowercase text-sm border"
                style={`background-color: ${tag.color ?? "#D5AD8E"}`}
              >
                <Icon name={tag.icon} size={tag.size ?? 16} class="shrink-0" />
                <span>{tag.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </Link>
  </Tooltip>
</div>
