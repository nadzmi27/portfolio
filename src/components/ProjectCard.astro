---
import Tooltip from "./Tooltip";
import Link from "./Link.astro";
import { Image, getImage } from "astro:assets";
import { Icon } from "astro-icon/components";
import watercolor from "../assets/watercolor.webp";
import paper from "../assets/paper.avif";
const watercolorBg = await getImage({ src: watercolor });
const paperBg = await getImage({ src: paper });

interface Skill {
  icon: string;
  name: string;
  size?: number;
}

interface Props {
  title: string;
  label: string;
  description: string;
  image: ImageMetadata;
  imageAlt?: string;
  href?: string;
  skills?: Skill[];
  borderColor?: string;
  bgColor?: string;
  skillColor?: string;
}

const {
  title,
  label,
  description,
  image,
  imageAlt = "",
  href = "#",
  skills,
  borderColor = "#000000",
  bgColor = "#FFFEF2",
  skillColor = "#FFFDD1",
} = Astro.props;
---

<Tooltip client:visible tooltip="Read case study">
  <Link href={href}>
    <div
      class="card-texture w-full h-fit py-4 px-4 border shadow-sm font-sans hover:scale-101 hover:shadow-xl"
      style={`--bg-url: url(${paperBg.src}); background-color: ${bgColor};`}
    >
      <!-- Header -->
      <div class="px-0.5">
        <h1 class="font-bold text-xl">
          {title}
        </h1>
        <h2 class="font-medium text-base">
          {label}
        </h2>
      </div>
      <!-- Image -->
      <div class="relative mt-3.5">
        <Image
          src={image}
          alt={imageAlt}
          loading="eager"
          class=`w-full block border`
          style={`border-color: ${borderColor};`}
          width={image.width}
          height={image.height}
        />
        <!-- Sits on top of the image, simulating the paper casting a shadow inward -->
        <div
          class="absolute inset-0 shadow-[inset_0_0.5px_12px_rgba(0,0,0,0.35)]"
        >
        </div>
      </div>
      <!-- Description -->
      <p class="px-0.5 pt-3 text-pretty leading-tight">
        {description}
      </p>
      <!-- Skills -->
      <div class="skills-divider mt-4 pt-4 flex flex-wrap gap-2">
        {
          skills?.map((skill) => (
            <div
              class="card-texture flex items-center gap-1.5 px-2 py-1 uppercase text-sm border border-black/40"
              style={`background-color: ${skillColor};`}
            >
              <Icon
                name={skill.icon}
                size={skill.size ?? 18}
                class="shrink-0"
              />
              <span>{skill.name}</span>
            </div>
          ))
        }
      </div>
    </div>
  </Link>
</Tooltip>

<style>
  /* Card Texture */
  .card-texture {
    position: relative;
  }

  .card-texture::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--bg-url); /* move bg image here */
    background-size: 100% auto;
    background-repeat: repeat-y;
    mix-blend-mode: multiply;
    opacity: 0.5; /* control strength here */
    z-index: 0;
  }

  .card-texture > * {
    position: relative;
    z-index: 1;
  }

  /* Skills  Divider*/
  .skills-divider {
    background-image: repeating-linear-gradient(
      90deg,
      #00000060 0px,
      /* Dash Length */ #00000060 8px,
      transparent 8px,
      transparent 12px
    );
    background-size: 100% 2px;
    background-repeat: no-repeat;
    background-position: top center;
  }
</style>
