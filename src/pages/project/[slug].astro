---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";

import TableOfContents from "../../components/Layout/TableOfContents";
import Layout from "../../components/Layout/Layout.astro";
import { Icon } from "astro-icon/components";
import Link from "../../components/Layout/Link.astro";

export async function getStaticPaths() {
  const projects = await getCollection(
    "projects",
    ({ data }) => data.hasCaseStudy === true,
  );
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const skillColor = "#DDDDDD";
const skillBorder = "#000000";
---

<Layout title={entry.data.title} description={entry.data.description}>
  <div
    data-bg="var(--color-background)"
    class="flex max-w-[840px] lg:max-w-[1400px] mx-auto px-4 mb-24 mt-4"
  >
    <!-- TOC floats outside, anchored to the left of the centered content -->
    <aside id="toc-aside" class="basis-1/5 hidden lg:block sticky top-0">
      <div
        style={`height: ${Math.round((entry.data.image.height * 900) / entry.data.image.width + 102)}px;`}
      >
      </div>
      <nav id="toc-nav" class="sticky top-24 w-[200px] ml-auto">
        <TableOfContents headings={headings} client:load />
      </nav>
    </aside>

    <!-- Centered content -->
    <div class="lg:basis-3/5">
      <Image
        id="case-study-image"
        src={entry.data.image}
        alt={entry.data.imageAlt ?? entry.data.title}
        class="object-cover border border-black/80 mb-6"
      />
      <div class="px-4 sm:px-6 md:px-8 lg:px-12 w-full">
        <h1 class="font-semibold text-3xl mb-2 mt-8">{entry.data.title}</h1>
        <div class="flex flex-row gap-2">
          {
            entry.data.links?.map((link) => (
              <Link
                href={link.href}
                openNew={true}
                class="w-fit h-fit flex flex-row items-center gap-2 px-2 py-1 border hover:brightness-95 translate-y-0.5"
                style={`background-color: var(--color-creamy-white); border-color: #000`}
              >
                {link.name && <span class="block">{link.name}</span>}
                <Icon name={link.icon} size={link.size ?? 18} />
              </Link>
            ))
          }
        </div>
        <article
          class:list={[
            "prose prose-neutral max-w-none",
            "prose-p:mt-3",
            "prose-headings:font-bold prose-headings:mb-0 prose-headings:mt-8",
            "prose-h1:text-2xl prose-h1:border-b prose-h1:border-black/20 prose-h1:pb-2",
            "prose-h2:text-xl prose-h2:border-b prose-h2:border-black/20 prose-h2:pb-2",
            "prose-h3:text-lg",
            // Figure
            "prose-figure:mt-6",
            "prose-img:my-0 prose-img:border prose-img:border-black/20",
            "prose-figcaption:text-gray-400 prose-figcaption:text-sm prose-figcaption:text-center prose-figcaption:mt-2",
            // Code blcok
            "prose-code:bg-black/10 prose-code:px-1 prose-code:text-sm",
            "prose-code:before:content-none prose-code:after:content-none",
          ]}
        >
          <Content />
        </article>
      </div>
    </div>
    <div class="basis-1/5 hidden lg:block"></div>
  </div>
</Layout>
