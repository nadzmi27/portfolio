---
import { getCollection, render } from "astro:content";

import TableOfContents from "../../components/Layout/TableOfContents";
import Layout from "../../components/Layout/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
// const bgColor = hexLighten("#CB9972", 0.2);
const bgColor = "var(--color-blog-background)"
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  backgroundColor={bgColor}
>
  <div
    data-bg={bgColor}
    class="flex max-w-[840px] lg:max-w-[1600px] mx-auto px-4 mb-24 mt-4"
    style=`background-color:${bgColor} ;`
  >
    <!-- TOC floats outside, anchored to the left of the centered content -->
    <aside id="toc-aside" class="basis-1/5 hidden lg:block sticky top-0">
      <div class="h-24"></div>
      <nav id="toc-nav" class="sticky top-24 w-[200px] ml-auto">
        <TableOfContents headings={headings} client:load />
      </nav>
    </aside>

    <!-- Centered content -->
    <div class="lg:basis-3/5">
      <div class="px-4 sm:px-6 md:px-8 lg:px-12 w-full">
        <h1 class="font-semibold text-3xl mb-2 mt-8">{entry.data.title}</h1>
        <article
          class:list={[
            "prose max-w-none text-pretty",
            "prose-p:mt-3 text-black",
            "prose-headings:font-bold prose-headings:mb-0 prose-headings:mt-8",
            "prose-h1:text-2xl",
            "prose-h2:text-xl",
            "prose-h3:text-lg",
            // Figure
            "prose-figure:mt-6",
            "prose-img:my-0 prose-img:border prose-img:border-black/20",
            "prose-figcaption:text-black/60 prose-figcaption:text-sm prose-figcaption:text-center prose-figcaption:mt-2",
            // Code blcok
            "prose-code:bg-black/10 prose-code:text-sm",
            "prose-code:before:content-none prose-code:after:content-none",
          ]}
        >
          <Content />
        </article>
      </div>
    </div>
    <div class="basis-1/5 hidden lg:block"></div>
    <!-- <article
      class="min-w-0 flex-1 prose prose-neutral dark:prose-invert max-w-none"
    >
      <h1>{entry.data.title}</h1>
      <p class="text-sm text-muted-foreground">
        {entry.data.date.toLocaleDateString("en-AU", { dateStyle: "long" })}
      </p>
      <Content />
    </article> -->
  </div>
</Layout>
